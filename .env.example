# Supabase — create a free project at https://supabase.com
# Run supabase/setup.sql in the SQL editor (replace CHANGE_ME_ADMIN_KEY)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Secret admin route hash: access via https://yoursite/#/ppl-ya-stats
VITE_ADMIN_PATH=ppl-ya-stats
